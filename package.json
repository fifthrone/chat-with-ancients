{
  "name": "chat-with-ancients",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev:mobile": "pnpm --filter @chat-with-ancients/mobile start",
    "dev:api": "pnpm --filter @chat-with-ancients/api dev",
    "db:up": "docker compose -f compose.yml --env-file .env up -d mysql",
    "db:down": "docker compose -f compose.yml down",
    "db:push": "pnpm --filter @chat-with-ancients/db db:push",
    "db:migrate": "pnpm --filter @chat-with-ancients/db db:migrate",
    "db:migrate:deploy": "pnpm --filter @chat-with-ancients/db db:migrate:deploy",
    "db:seed": "pnpm --filter @chat-with-ancients/db db:seed",
    "db:studio": "pnpm --filter @chat-with-ancients/db db:studio",
    "lint": "biome check apps/api/src apps/mobile/src/chat apps/mobile/src/config apps/mobile/App.tsx",
    "test:api": "pnpm --filter @chat-with-ancients/api test:run",
    "test:mobile": "pnpm --filter @chat-with-ancients/mobile test:run",
    "typecheck:mobile": "pnpm --filter @chat-with-ancients/mobile typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10"
  }
}
