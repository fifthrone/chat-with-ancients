generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Ancient {
  id           Int      @id @default(autoincrement())
  slug         String   @unique @db.VarChar(64)
  name         String   @db.VarChar(128)
  region       String   @db.VarChar(128)
  latitude     Decimal  @db.Decimal(9, 6)
  longitude    Decimal  @db.Decimal(9, 6)
  avatarUrl    String?  @db.VarChar(512)
  eraLabel     String   @db.VarChar(128)
  shortBio     String   @db.VarChar(500)
  systemPrompt String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  conversations Conversation[]

  @@index([region])
  @@index([latitude, longitude])
}

model Conversation {
  id        Int       @id @default(autoincrement())
  clientId  String    @db.VarChar(128)
  ancientId Int
  title     String?   @db.VarChar(255)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  ancient   Ancient   @relation(fields: [ancientId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([clientId, ancientId])
  @@index([ancientId])
}

model Message {
  id                Int           @id @default(autoincrement())
  conversationId    Int
  role              MessageRole
  content           String        @db.Text
  tokenCount        Int?
  providerMessageId String?       @db.VarChar(255)
  createdAt         DateTime      @default(now())
  conversation      Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum MessageRole {
  user
  assistant
  system
}
